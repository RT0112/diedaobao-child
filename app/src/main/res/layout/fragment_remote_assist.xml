<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- 空闲状态：发起协助按钮 -->
    <LinearLayout
        android:id="@+id/container_idle"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="visible">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@android:drawable/ic_menu_share"
            android:contentDescription="远程协助"
            android:tint="#2196F3" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="远程协助"
            android:textSize="22sp"
            android:textColor="#212121"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="远程查看并操作老人手机屏幕\n帮助老人解决操作问题"
            android:textSize="14sp"
            android:textColor="#757575"
            android:gravity="center" />

        <Button
            android:id="@+id/btn_start_assist"
            android:layout_width="200dp"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:text="发起协助"
            android:textSize="18sp"
            android:textColor="@android:color/white"
            android:backgroundTint="#2196F3" />
    </LinearLayout>

    <!-- 等待状态 -->
    <LinearLayout
        android:id="@+id/container_waiting"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="#2196F3" />

        <TextView
            android:id="@+id/tv_waiting_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="正在请求协助..."
            android:textSize="16sp"
            android:textColor="#757575" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="等待老人同意请求"
            android:textSize="13sp"
            android:textColor="#BDBDBD" />

        <Button
            android:id="@+id/btn_cancel_request"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginTop="24dp"
            android:text="取消请求"
            android:textColor="#757575"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- 协助中 -->
    <LinearLayout
        android:id="@+id/container_assisting"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- 顶部栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#4CAF50"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🟢 协助中"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:layout_marginEnd="16dp" />

            <Button
                android:id="@+id/btn_end_assist"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="结束"
                android:textColor="@android:color/white"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- 屏幕画面区域 -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#000000">

            <ImageView
                android:id="@+id/iv_screen"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:contentDescription="老人屏幕画面" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="16dp"
                android:text="💡 点击画面可远程操作老人手机"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:background="#40000000"
                android:padding="8dp" />
        </FrameLayout>

        <!-- 底部工具栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@android:color/white"
            android:gravity="center"
            android:orientation="horizontal"
            android:elevation="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💡 点击画面远程操作老人手机"
                android:textSize="13sp"
                android:textColor="#757575" />
        </LinearLayout>
    </LinearLayout>

    <!-- 错误状态 -->
    <LinearLayout
        android:id="@+id/container_error"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="😕"
            android:textSize="64sp" />

        <TextView
            android:id="@+id/tv_error_msg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="发生错误"
            android:textSize="16sp"
            android:textColor="#F44336"
            android:gravity="center" />

        <Button
            android:id="@+id/btn_retry"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="200dp"
            android:layout_height="48dp"
            android:layout_marginTop="24dp"
            android:text="重试"
            android:textColor="#2196F3" />
    </LinearLayout>

</FrameLayout>
